{
  "meta": {
    "schema_version": "1.1.0",
    "awf_version": "3.3.1",
    "last_audit": "2026-03-24"
  },
  "project": {
    "name": "YTSummary",
    "type": "AI Summarizer (Android/Python)",
    "status": "production_ready"
  },
  "tech_stack": {
    "frontend": {
      "language": "Kotlin",
      "framework": "Jetpack Compose",
      "database": "Room + SQLCipher (Encrypted)",
      "network": "OkHttp + Retrofit"
    },
    "backend": {
      "language": "Python",
      "framework": "FastAPI",
      "libraries": ["youtube-transcript-api (pip)", "slowapi", "httpx", "cachetools"],
      "deployment": "Railway.app (Dockerized)",
      "version": "1.1.1"
    }
  },
  "deployment": {
    "production_url": "https://ytsummary-production.up.railway.app",
    "root_directory": "/backend",
    "exposed_port": "DYNAMIC ($PORT)",
    "env_vars": ["PORT", "ALLOWED_ORIGINS"]
  },
  "api_endpoints": [
    { "path": "/", "desc": "Health check" },
    { "path": "/api/metadata", "desc": "Fetch YouTube video metadata" },
    { "path": "/api/transcript", "desc": "Fetch cleaned YouTube transcript (VI/EN)" }
  ],
  "security_rules": [
    "Gemini API Keys must be sent via Headers, NEVER URLs",
    "Database must be encrypted with SQLCipher",
    "Backend must have rate limiting (10 req/min)",
    "Backend CORS restricted to Railway domains and trusted origins",
    "Production error messages sanitized"
  ],
  "knowledge_items": {
    "patterns": [
      "Key Rotation Strategy for Gemini API",
      "Encrypted Room Database with SupportFactory",
      "In-memory Caching for YouTube Transcripts",
      "Centralized Constants for API URLs",
      "Direct Python Entrypoint for Railway (Port stability)"
    ],
    "gotchas": [
      "502 Error: Ensure official pip version of youtube-transcript-api on Linux Cloud",
      "Railway: Requires direct python entrypoint for $PORT binding stability",
      "Avoiding Redundant Prompt Building in Android (Current focus)"
    ]
  }
}
